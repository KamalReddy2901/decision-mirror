# Server-only secret (set in your hosting provider's server/runtime env settings)
# Option 1: Single API key (backward compatible)
GROQ_API_KEY=

# Option 2: Multiple API keys for automatic rotation on rate limits (recommended)
# Comma-separated list - if one key hits rate limit, automatically switches to next
# Example: GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_API_KEYS=

# Frontend mode (safe for public deployment)
VITE_AI_MODE=server
VITE_AI_PROXY_PATH=/api/groq

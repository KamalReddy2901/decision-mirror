# Frontend AI mode:
# - client: users provide their own key in Settings (or use VITE_GROQ_API_KEY below)
# - server: frontend calls your backend proxy (recommended for public deployment)
VITE_AI_MODE=server

# Optional custom proxy path (default: /api/groq)
VITE_AI_PROXY_PATH=/api/groq

# Optional only for client mode (NOT secure for public apps)
VITE_GROQ_API_KEY=
